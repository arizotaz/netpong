{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Pong",
            "command": "/usr/bin/gcc",
            "args": [
                "-Wall",
                "-g",
                "main.c",
                "court.c",
                "network/*.c",
                "-o",
                "netpong",
                "-lncurses"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}